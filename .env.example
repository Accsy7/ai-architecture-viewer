# Optional local runtime settings.
PORT=8800
# Viewer state, layout, documents, and review history.
# VIEWER_PROJECT_DIR=projects/demo
# Repository inspected by the external coding agent. Evidence paths are relative to this directory.
# VIEWER_WORKSPACE_ROOT=D:/work/my-project

# Optional MCP bridge settings.
# VIEWER_BASE_URL=http://127.0.0.1:8800
# Set to false when the viewer is managed by another process.
# VIEWER_MCP_AUTOSTART=true
