{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-architecture-viewer.local/protocol/ai-coding-exchange.schema.json",
  "title": "AI Architecture Viewer Coding Exchange",
  "oneOf": [
    { "$ref": "#/$defs/taskRequest" },
    { "$ref": "#/$defs/evidenceManifest" },
    { "$ref": "#/$defs/architectureSnapshot" },
    { "$ref": "#/$defs/architectureProposal" },
    { "$ref": "#/$defs/implementationReport" }
  ],
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["git-commit", "workspace", "release"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "legacyEvidenceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "lineStart", "lineEnd", "summary", "contentHash", "basis"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "path": { "$ref": "#/$defs/relativePath" },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "excerpt": { "type": "string", "maxLength": 4000 },
        "contentHash": { "$ref": "#/$defs/hash" },
        "basis": { "enum": ["fact", "inference"] }
      }
    },
    "fileEvidenceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceKind", "basis", "path", "lineStart", "lineEnd", "summary", "contentHash"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "sourceKind": { "const": "workspace-file" },
        "basis": { "enum": ["user-confirmed", "design-document", "code-fact", "agent-inference"] },
        "path": { "$ref": "#/$defs/relativePath" },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "excerpt": { "type": "string", "maxLength": 4000 },
        "contentHash": { "$ref": "#/$defs/hash" }
      }
    },
    "discussionEvidenceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceKind", "basis", "sourceLabel", "recordedAt", "summary", "excerpt"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "sourceKind": { "const": "discussion" },
        "basis": { "enum": ["user-confirmed", "agent-inference"] },
        "sourceLabel": { "type": "string", "minLength": 1, "maxLength": 200 },
        "recordedAt": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "excerpt": { "type": "string", "minLength": 1, "maxLength": 4000 }
      }
    },
    "evidenceEntry": {
      "oneOf": [
        { "$ref": "#/$defs/fileEvidenceEntry" },
        { "$ref": "#/$defs/discussionEvidenceEntry" }
      ]
    },
    "architectureNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "purpose", "technical", "product", "authorization", "evidenceIds"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "technical": { "type": "string", "minLength": 1, "maxLength": 500 },
        "product": { "type": "string", "minLength": 1, "maxLength": 500 },
        "authorization": { "type": "string", "minLength": 1, "maxLength": 500 },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } }
      }
    },
    "architectureEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "label", "relationType", "evidenceIds"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "source": { "$ref": "#/$defs/stableId" },
        "target": { "$ref": "#/$defs/stableId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "relationType": { "enum": ["flow", "support", "reference", "governance", "handoff"] },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } }
      }
    },
    "architectureChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "targetType", "targetId", "summary", "evidenceIds", "patch"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "kind": { "enum": ["add", "update", "remove"] },
        "targetType": { "enum": ["node", "edge"] },
        "targetId": { "$ref": "#/$defs/stableId" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } },
        "patch": { "type": ["object", "null"] }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "summary", "advantages", "disadvantages"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "advantages": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
        "disadvantages": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 500 } }
      }
    },
    "testResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "outcome", "summary"],
      "properties": {
        "command": { "type": "string", "minLength": 1, "maxLength": 500 },
        "outcome": { "enum": ["passed", "failed", "not-run"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "acceptanceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "status", "evidenceIds"],
      "properties": {
        "criterion": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "status": { "enum": ["satisfied", "unsatisfied", "unverified"] },
        "evidenceIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } }
      }
    },
    "drift": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "targetId", "summary", "evidenceIds"],
      "properties": {
        "kind": { "enum": ["missing", "extra", "changed", "unverified"] },
        "targetId": { "$ref": "#/$defs/stableId" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "evidenceIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } }
      }
    },
    "taskRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "goal", "constraints", "nonGoals", "acceptanceCriteria", "decisionsRequired"],
      "properties": {
        "schemaVersion": { "enum": ["1.0.0", "1.1.0"] },
        "artifactType": { "const": "task-request" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "goal": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "constraints": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "nonGoals": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "acceptanceCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "decisionsRequired": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } }
      }
    },
    "evidenceManifest": {
      "oneOf": [
        { "$ref": "#/$defs/evidenceManifestV1" },
        { "$ref": "#/$defs/evidenceManifestV11" }
      ]
    },
    "evidenceManifestV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "projectRevision", "entries"],
      "properties": {
        "schemaVersion": { "const": "1.0.0" },
        "artifactType": { "const": "evidence-manifest" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "projectRevision": { "$ref": "#/$defs/revision" },
        "entries": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/legacyEvidenceEntry" } }
      }
    },
    "evidenceManifestV11": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "projectRevision", "entries"],
      "properties": {
        "schemaVersion": { "const": "1.1.0" },
        "artifactType": { "const": "evidence-manifest" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "projectRevision": { "$ref": "#/$defs/revision" },
        "entries": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidenceEntry" } }
      }
    },
    "architectureSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "project", "scope", "nodes", "edges", "assumptions", "unknowns", "evidenceManifest"],
      "properties": {
        "schemaVersion": { "enum": ["1.0.0", "1.1.0"] },
        "artifactType": { "const": "architecture-snapshot" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "revision"],
          "properties": {
            "name": { "type": "string", "minLength": 1, "maxLength": 200 },
            "revision": { "$ref": "#/$defs/revision" }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "excluded"],
          "properties": {
            "included": { "type": "array", "items": { "$ref": "#/$defs/relativePath" } },
            "excluded": { "type": "array", "items": { "$ref": "#/$defs/relativePath" } }
          }
        },
        "nodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/architectureNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/architectureEdge" } },
        "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "unknowns": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "evidenceManifest": { "$ref": "#/$defs/relativePath" }
      }
    },
    "architectureProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "requestId", "baseSnapshotId", "title", "summary", "options", "recommendedOptionId", "changes", "acceptanceCriteria", "risks", "decisionsRequired", "evidenceManifest"],
      "properties": {
        "schemaVersion": { "enum": ["1.0.0", "1.1.0"] },
        "artifactType": { "const": "architecture-proposal" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "requestId": { "$ref": "#/$defs/stableId" },
        "baseSnapshotId": { "$ref": "#/$defs/stableId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "options": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/option" } },
        "recommendedOptionId": { "$ref": "#/$defs/stableId" },
        "changes": { "type": "array", "minItems": 1, "maxItems": 50, "items": { "$ref": "#/$defs/architectureChange" } },
        "acceptanceCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "risks": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "decisionsRequired": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "evidenceManifest": { "$ref": "#/$defs/relativePath" }
      }
    },
    "implementationReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactType", "artifactId", "createdAt", "requestId", "approvedProposalId", "status", "resultingRevision", "changedFiles", "tests", "acceptanceResults", "drift", "unresolved", "evidenceManifest", "resultingSnapshot"],
      "properties": {
        "schemaVersion": { "enum": ["1.0.0", "1.1.0"] },
        "artifactType": { "const": "implementation-report" },
        "artifactId": { "$ref": "#/$defs/stableId" },
        "createdAt": { "type": "string", "format": "date-time" },
        "requestId": { "$ref": "#/$defs/stableId" },
        "approvedProposalId": { "$ref": "#/$defs/stableId" },
        "status": { "enum": ["complete", "partial", "blocked"] },
        "resultingRevision": { "$ref": "#/$defs/revision" },
        "changedFiles": { "type": "array", "items": { "$ref": "#/$defs/relativePath" } },
        "tests": { "type": "array", "items": { "$ref": "#/$defs/testResult" } },
        "acceptanceResults": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/acceptanceResult" } },
        "drift": { "type": "array", "items": { "$ref": "#/$defs/drift" } },
        "unresolved": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "evidenceManifest": { "$ref": "#/$defs/relativePath" },
        "resultingSnapshot": { "$ref": "#/$defs/relativePath" }
      }
    }
  }
}
